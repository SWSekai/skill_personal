#!/bin/sh
# =============================================================
#  Pre-commit hook: block skill/config files from project commits
#  Installed by sekai-workflow/sp-init.bat
# =============================================================

# 使用者工作資料夾名稱可透過 USER_WORKDIR 環境變數覆寫，預設 .workdir/
USER_WORKDIR="${USER_WORKDIR:-.workdir/}"
BLOCKED_PATTERNS=".claude/ Sekai_workflow/ CLAUDE.md ${USER_WORKDIR}"

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED" ]; then
    exit 0
fi

FOUND_BLOCKED=""
for pattern in $BLOCKED_PATTERNS; do
    MATCHES=$(echo "$STAGED" | grep "^${pattern}" 2>/dev/null)
    if [ -n "$MATCHES" ]; then
        FOUND_BLOCKED="${FOUND_BLOCKED}${MATCHES}
"
    fi
done

if [ -n "$FOUND_BLOCKED" ]; then
    echo ""
    echo "=========================================="
    echo "  COMMIT BLOCKED: skill/config files detected"
    echo "=========================================="
    echo ""
    echo "The following files must NOT be in project version control:"
    echo ""
    echo "$FOUND_BLOCKED" | sed '/^$/d' | while read -r f; do
        echo "  - $f"
    done
    echo ""
    echo "These files are managed separately (see .gitignore)."
    echo "Run: git reset HEAD <file> to unstage them."
    echo ""
    exit 1
fi

exit 0
